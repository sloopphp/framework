{
    "name": "sloopphp/framework",
    "description": "A modern PHP framework - lightweight, API-first, AI-friendly",
    "type": "library",
    "license": "MIT",
    "keywords": ["framework", "php", "api", "lightweight", "modern"],
    "homepage": "https://github.com/sloopphp/framework",
    "authors": [
        {
            "name": "Daisuke Miura"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-intl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "nyholm/psr7": "^1.8",
        "monolog/monolog": "^3.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.32.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0 || ^12.0",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Sloop\\": "src/Sloop/"
        },
        "files": [
            "src/Sloop/Helpers/path.php",
            "src/Sloop/Helpers/env.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Sloop\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true
        }
    }
}
