{
    "name": "sloopphp/framework",
    "description": "A modern PHP framework - lightweight, API-first, AI-friendly",
    "type": "library",
    "license": "MIT",
    "keywords": ["framework", "php", "api", "lightweight", "modern"],
    "homepage": "https://github.com/sloopphp/framework",
    "authors": [
        {
            "name": "Daisuke Miura"
        }
    ],
    "require": {
        "php": "^8.4",
        "nyholm/psr7": "^1.8",
        "monolog/monolog": "^3.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sloop\\": "src/Sloop/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sloop\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
