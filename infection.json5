{
    "$schema": "./vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ]
    },
    "timeout": 30,
    "logs": {
        "text": "build/infection/infection.log",
        "html": "build/infection/infection.html",
        "summary": "build/infection/summary.log",
        "json": "build/infection/infection.json"
    },
    "tmpDir": "build/infection/tmp",
    "minMsi": 95,
    "minCoveredMsi": 95,
    "mutators": {
        "@default": true,
        // Equivalent mutants: the mutation changes the AST but the program
        // semantics are preserved, so no test can distinguish them. Ignoring
        // them is the standard workflow (mutation testing cannot kill what
        // is not observable by tests).
        "LogicalAndSingleSubExprNegation": {
            // Container::resolveBinding line 142: the cached-singleton check
            // is a defensive layer. get() already returns early when the id
            // is in $this->instances, so this inner check is unreachable on
            // every call path that exists today. We keep it because it is a
            // correct invariant for resolveBinding's API contract, but the
            // negated branch is equivalent to the original.
            "ignore": [
                "Sloop\\Container\\Container::resolveBinding"
            ]
        },
        "TrueValue": {
            // Container::autowire stores a sentinel in $this->resolving whose
            // value is only checked via isset(). The sentinel is semantically
            // a set-membership flag, not a truth value; true/false are
            // indistinguishable through isset, making TrueValue an equivalent
            // mutant. PHP's idiomatic set-of-strings representation
            // (array<string, true>) is preserved deliberately.
            "ignore": [
                "Sloop\\Container\\Container::autowire"
            ]
        },
        "IncrementInteger": {
            // Str::randomHex computes the byte count as `intdiv($length + 1, 2)`
            // so that odd-length requests round up. Changing the `+ 1` to `+ 2`
            // simply asks for one extra byte that substr() then trims off,
            // leaving the visible output unchanged (equivalent mutant).
            // \Random\Randomizer is a final core class whose state machine
            // produces deterministic leading bytes, so a larger getBytes()
            // call yields the same hex prefix. No black-box test can observe
            // the difference, so the mutation cannot be killed.
            "ignore": [
                "Sloop\\Support\\Str::randomHex"
            ]
        },
        "DecrementInteger": {
            // Str::randomHex: same root cause as IncrementInteger above.
            // Changing the divisor from 2 to 1 just asks for more bytes that
            // are then trimmed by substr(), leaving the output unchanged.
            // Str::random: getInt(0, $charsLen - 1) → getInt(-1, $charsLen - 1)
            // expands the range so -1 may surface; PHP's $chars[-1] resolves
            // to the last character ('9'), so the result keeps the same
            // alphabet and length, only the per-character distribution shifts
            // by ~1.6%. No deterministic black-box assertion can observe the
            // shift without running thousands of samples; equivalent in
            // practice for unit-test purposes.
            "ignore": [
                "Sloop\\Support\\Str::randomHex",
                "Sloop\\Support\\Str::random"
            ]
        },
        "Concat": {
            // Str::snake builds its cache key as `$value . $delimiter`.
            // Reversing the operands to `$delimiter . $value` still yields
            // a unique cache key for each (value, delimiter) pair, so the
            // observable behaviour (return value, cache hit/miss outcome) is
            // identical. Equivalent mutant.
            "ignore": [
                "Sloop\\Support\\Str::snake"
            ]
        },
        "ReturnRemoval": {
            // Str::snake / Str::studly cache hit branches return the cached
            // value early. Removing the early return causes the body to run
            // again and overwrite the cache with the same computed value, so
            // the visible output is unchanged; only an unobservable performance
            // difference remains. Equivalent in black-box test terms.
            "ignore": [
                "Sloop\\Support\\Str::snake",
                "Sloop\\Support\\Str::studly"
            ]
        },
        "ArrayItemRemoval": {
            // Str::studly's `preg_split('/[-_\s]+/', $value) ?: [$value]`
            // fallback is unreachable: the regex is valid so preg_split never
            // returns false, and an empty input '' produces ['']—truthy, so
            // the `?:` branch is never taken. Removing $value from the
            // fallback array therefore changes nothing observable.
            "ignore": [
                "Sloop\\Support\\Str::studly"
            ]
        }
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testdox --testsuite=Unit"
}
