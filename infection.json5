{
    "$schema": "./vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ]
    },
    "timeout": 30,
    "logs": {
        "text": "build/infection/infection.log",
        "html": "build/infection/infection.html",
        "summary": "build/infection/summary.log",
        "json": "build/infection/infection.json"
    },
    "tmpDir": "build/infection/tmp",
    "minMsi": 95,
    "minCoveredMsi": 95,
    "mutators": {
        "@default": true,
        // Equivalent mutants: the mutation changes the AST but the program
        // semantics are preserved, so no test can distinguish them. Ignoring
        // them is the standard workflow (mutation testing cannot kill what
        // is not observable by tests).
        "LogicalAndSingleSubExprNegation": {
            // Container::resolveBinding line 142: the cached-singleton check
            // is a defensive layer. get() already returns early when the id
            // is in $this->instances, so this inner check is unreachable on
            // every call path that exists today. We keep it because it is a
            // correct invariant for resolveBinding's API contract, but the
            // negated branch is equivalent to the original.
            "ignore": [
                "Sloop\\Container\\Container::resolveBinding"
            ]
        },
        "TrueValue": {
            // Container::autowire stores a sentinel in $this->resolving whose
            // value is only checked via isset(). The sentinel is semantically
            // a set-membership flag, not a truth value; true/false are
            // indistinguishable through isset, making TrueValue an equivalent
            // mutant. PHP's idiomatic set-of-strings representation
            // (array<string, true>) is preserved deliberately.
            "ignore": [
                "Sloop\\Container\\Container::autowire"
            ]
        }
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testdox --testsuite=Unit"
}
